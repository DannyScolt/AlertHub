APP_ENV=development
HTTP_PORT=8080

POSTGRES_USER=alerthub
POSTGRES_PASSWORD=alerthub
POSTGRES_DB=alerthub
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgres://alerthub:alerthub@localhost:5432/alerthub?sslmode=disable

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

DEVICE_API_KEY_PREFIX=ah_dev
DEVICE_RESTORE_WINDOW_DAYS=90

SWAGGER_ENABLED=true
